rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ─────────────────────────────────────────────────────────────
    function isAdmin() {
      return request.auth != null
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function isClientFor(clientId) {
      return request.auth != null
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clientId == clientId;
    }

    // ── Users ────────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if request.auth != null
                  && (request.auth.uid == uid || isAdmin());
      // Clients may create their own doc (role locked to "client"); admin writes via Admin SDK
      allow create: if request.auth != null
                    && request.auth.uid == uid
                    && request.resource.data.role == "client";
      allow update: if request.auth != null
                    && request.auth.uid == uid
                    && !request.resource.data.diff(resource.data).affectedKeys().hasAny(["role"]);
      allow write: if isAdmin();
    }

    // ── Enquiries (existing) ─────────────────────────────────────────────────
    match /enquiries/{id} {
      allow read: if request.auth != null
                  && (request.auth.uid == resource.data.userId || isAdmin());
      allow write: if false; // all writes via Admin SDK only
    }

    // ── CRM ──────────────────────────────────────────────────────────────────
    match /contacts/{id} {
      allow read, write: if isAdmin();
    }

    match /deals/{id} {
      allow read, write: if isAdmin();
    }

    match /activities/{id} {
      allow read, write: if isAdmin();
    }

    // ── Email ────────────────────────────────────────────────────────────────
    match /emails/{id} {
      allow read, write: if isAdmin();
    }

    // ── Sequences ────────────────────────────────────────────────────────────
    match /sequences/{id} {
      allow read, write: if isAdmin();
    }

    match /sequence_enrollments/{id} {
      allow read, write: if isAdmin();
    }

    // ── Client portal ────────────────────────────────────────────────────────
    match /clients/{id} {
      allow read: if isAdmin() || isClientFor(id);
      allow write: if isAdmin();
    }

    match /projects/{id} {
      allow read: if isAdmin() || isClientFor(resource.data.clientId);
      allow write: if isAdmin();
    }

    match /tasks/{id} {
      allow read: if isAdmin() || isClientFor(resource.data.clientId);
      allow write: if isAdmin();
    }

    match /tasks/{taskId}/comments/{commentId} {
      allow read: if isAdmin() || isClientFor(
        get(/databases/$(database)/documents/tasks/$(taskId)).data.clientId
      );
      allow write: if isAdmin() || isClientFor(
        get(/databases/$(database)/documents/tasks/$(taskId)).data.clientId
      );
    }

    match /invoices/{id} {
      allow read: if isAdmin() || isClientFor(resource.data.clientId);
      allow write: if isAdmin();
    }

    match /recurring_schedules/{id} {
      allow read, write: if isAdmin();
    }

    // ── Marketing ────────────────────────────────────────────────────────────
    match /campaigns/{id} {
      allow read, write: if isAdmin();
    }

    // ── AI audit log ─────────────────────────────────────────────────────────
    match /ai_action_log/{id} {
      allow read, write: if isAdmin();
    }

    // ── Organizations ────────────────────────────────────────────────────────
    // Note: members array items must have exactly {userId, role} — no extra fields —
    // for hasAny map-equality checks to work correctly.
    match /organizations/{orgId} {
      allow read: if isAdmin() || (request.auth != null &&
        (resource.data.members.hasAny([{ userId: request.auth.uid, role: 'owner' }]) ||
         resource.data.members.hasAny([{ userId: request.auth.uid, role: 'admin' }]) ||
         resource.data.members.hasAny([{ userId: request.auth.uid, role: 'member' }])));
      allow create: if request.auth != null &&
        request.resource.data.createdBy == request.auth.uid;
      allow update: if isAdmin() || (request.auth != null &&
        (resource.data.members.hasAny([{ userId: request.auth.uid, role: 'owner' }]) ||
         resource.data.members.hasAny([{ userId: request.auth.uid, role: 'admin' }])));
      allow delete: if request.auth != null &&
        resource.data.members.hasAny([{ userId: request.auth.uid, role: 'owner' }]);
    }

    // ──────────────────────────────────────────────────────────────────────────
    // New collections (2026-04-16 agent API skills build)
    //
    // Rule of thumb: writes are via Admin SDK only (deny client writes),
    // reads are admin-only unless a specific client-visible surface is
    // defined. The /api/v1 routes use `withAuth` on the server; the rules
    // below enforce defense in depth for direct Firestore access.
    // ──────────────────────────────────────────────────────────────────────────

    // Idempotency cache — never client-readable or writable.
    match /idempotency_keys/{id} {
      allow read, write: if false;
    }

    // Unified comments — admin read/write. Clients cannot see each other's
    // comment threads (even on their own resources) without deliberate
    // per-resource exposure later.
    match /comments/{id} {
      allow read, write: if isAdmin();
    }

    // Standalone tasks (distinct from the nested /tasks/{taskId}/comments above).
    // Admin only; if a client needs to see their tasks we'd add an orgId check.
    match /tasks/{id} {
      allow read: if isAdmin() || (resource.data.orgId != null && isClientFor(resource.data.orgId));
      allow write: if isAdmin();
    }

    // Notifications — admin read/write. Per-user visibility via API (withAuth)
    // rather than client-side Firestore reads.
    match /notifications/{id} {
      allow read, write: if isAdmin();
    }

    // File metadata — admin read/write. Uploads are via Admin SDK through /upload.
    match /uploads/{id} {
      allow read, write: if isAdmin();
    }

    // Calendar events — admin read/write.
    match /calendar_events/{id} {
      allow read, write: if isAdmin();
    }

    // Time tracking — admin read/write. Self-only reads are API-gated.
    match /time_entries/{id} {
      allow read, write: if isAdmin();
    }

    // Expenses — admin read/write.
    match /expenses/{id} {
      allow read, write: if isAdmin();
    }

    // Forms — admin read/write. Public submit goes through the /api/v1/forms/[slug]/submit
    // route which uses Admin SDK; no client-side form submit to Firestore.
    match /forms/{id} {
      allow read, write: if isAdmin();
    }

    match /form_submissions/{id} {
      allow read, write: if isAdmin();
    }

    // Form rate-limit buckets — never client-readable or writable.
    match /form_rate_limits/{id} {
      allow read, write: if false;
    }

    // Outbound webhooks system — admin only. Queue + deliveries are internal.
    match /outbound_webhooks/{id} {
      allow read, write: if isAdmin();
    }

    match /webhook_queue/{id} {
      allow read, write: if false;
    }

    match /webhook_deliveries/{id} {
      allow read, write: if isAdmin();
    }

    // Properties — managed via server-side API only
    match /properties/{docId} {
      allow read, write: if false;
    }

    // Analytics — all written via Admin SDK (ingest endpoint), all queried via admin-authed API
    match /product_events/{id} {
      allow read, write: if false;
    }

    match /product_sessions/{id} {
      allow read, write: if false;
    }

    match /product_funnels/{id} {
      allow read, write: if false;
    }

    // Analytics rate limiting — internal only
    match /analytics_rate_limits/{id} {
      allow read, write: if false;
    }

    // ──────────────────────────────────────────────────────────────────────────
    // SEO Sprint Manager (2026-05-04)
    //
    // All writes via Admin SDK only. Reads are tenant-scoped via orgId on the
    // auth token claim. Audits expose an optional public-share token for
    // read-only deep links. Optimization log is admin-internal only.
    // ──────────────────────────────────────────────────────────────────────────
    match /seo_sprints/{id} {
      allow read: if request.auth != null && resource.data.orgId == request.auth.token.orgId;
      allow write: if false; // admin SDK only
    }
    match /seo_tasks/{id} {
      allow read: if request.auth != null && resource.data.orgId == request.auth.token.orgId;
      allow write: if false;
    }
    match /seo_keywords/{id} {
      allow read: if request.auth != null && resource.data.orgId == request.auth.token.orgId;
      allow write: if false;
    }
    match /seo_backlinks/{id} {
      allow read: if request.auth != null && resource.data.orgId == request.auth.token.orgId;
      allow write: if false;
    }
    match /seo_content/{id} {
      allow read: if request.auth != null && resource.data.orgId == request.auth.token.orgId;
      allow write: if false;
    }
    match /seo_audits/{id} {
      allow read: if request.auth != null
        && (resource.data.orgId == request.auth.token.orgId
            || resource.data.publicShareToken == request.query.token);
      allow write: if false;
    }
    match /seo_optimizations/{id} {
      // Admin only — clients never read optimization log
      allow read: if false;
      allow write: if false;
    }
    // All Hermes collections go through API routes (server SDK). Block direct client access.
    match /hermes_profile_links/{orgId} {
      allow read, write: if false;
    }
    match /hermes_runs/{id} {
      allow read, write: if false;
    }
    match /hermes_conversations/{convId} {
      allow read, write: if false;
      match /messages/{msgId} {
        allow read, write: if false;
      }
    }
  }
}
