# Optional nginx reverse proxy for Hermes profile API servers.
# Preferred: keep Hermes bound to 127.0.0.1/private network and let PiB call private URLs.
# Use this only when you need a single HTTPS entrypoint.

map $http_upgrade $connection_upgrade {
  default upgrade;
  '' close;
}

server {
  listen 443 ssl http2;
  server_name hermes-api.example.com;

  ssl_certificate /etc/letsencrypt/live/hermes-api.example.com/fullchain.pem;
  ssl_certificate_key /etc/letsencrypt/live/hermes-api.example.com/privkey.pem;

  # Add IP allowlisting here when PiB has stable egress or private tunnel IPs.
  # allow 10.0.0.0/8;
  # deny all;

  proxy_http_version 1.1;
  proxy_set_header Host $host;
  proxy_set_header X-Real-IP $remote_addr;
  proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
  proxy_set_header X-Forwarded-Proto $scheme;
  proxy_set_header Upgrade $http_upgrade;
  proxy_set_header Connection $connection_upgrade;
  proxy_buffering off;

  # One path prefix per profile. PiB baseUrl would be:
  #   https://hermes-api.example.com/profiles/i-am-ballito
  location /profiles/i-am-ballito/ {
    rewrite ^/profiles/i-am-ballito/(.*)$ /$1 break;
    proxy_pass http://127.0.0.1:8651;
  }

  location /profiles/elemental/ {
    rewrite ^/profiles/elemental/(.*)$ /$1 break;
    proxy_pass http://127.0.0.1:8652;
  }

  location /profiles/deidre-ras-biokinetics/ {
    rewrite ^/profiles/deidre-ras-biokinetics/(.*)$ /$1 break;
    proxy_pass http://127.0.0.1:8653;
  }
}
