# Copy to /etc/hermes/profiles/<profile>.env and chmod 600.
# Example: /etc/hermes/profiles/i-am-ballito.env

# Hermes profile identity. Must match the systemd instance name used by hermes@<profile>.service.
API_SERVER_ENABLED=true
# Use 127.0.0.1 when nginx/Caddy runs on the same VPS.
# Use the VPS private interface IP or 0.0.0.0 only when firewalling profile ports to PiB/private-network sources.
API_SERVER_HOST=127.0.0.1
API_SERVER_PORT=8651
API_SERVER_MODEL_NAME=i-am-ballito

# Generate a unique secret per profile:
#   openssl rand -base64 32
# Store the same value only in the PiB server-side hermes_profile_links document/secret store.
API_SERVER_KEY=replace-with-profile-specific-secret

# Provider/model settings for this profile. Keep real secrets out of git.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
# HERMES_DEFAULT_MODEL=

# Optional profile-specific runtime controls.
# HERMES_LOG_LEVEL=info
# HERMES_DISABLE_TERMINAL=false
# HERMES_DISABLE_FILE_TOOLS=false
